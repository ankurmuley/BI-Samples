    <DataSet Name="DSCompanyCoverageState">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>="DEFINE" &amp; vbCrLf &amp;
"    VAR ParamCompany = """ &amp; Parameters!Company.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamState = """ &amp; Parameters!State.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamLOB = """ &amp; Parameters!LOB.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamUnderwriter = """ &amp; Parameters!Underwriter.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamCarrier = """ &amp; Parameters!Carrier.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamAgency = """ &amp; Parameters!Agency.Value &amp; """" &amp; vbCrLf &amp;
"    VAR StartDate = DATE(" &amp; Year(Parameters!StartDate.Value) &amp; "," &amp; Month(Parameters!StartDate.Value) &amp; "," &amp; Day(Parameters!StartDate.Value) &amp; ")" &amp; vbCrLf &amp;
"    VAR EndDate = DATE(" &amp; Year(Parameters!EndDate.Value) &amp; "," &amp; Month(Parameters!EndDate.Value) &amp; "," &amp; Day(Parameters!EndDate.Value) &amp; ")" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"EVALUATE" &amp; vbCrLf &amp;
"SUMMARIZECOLUMNS (" &amp; vbCrLf &amp;
"    golddimpolicy[clientCode]," &amp; vbCrLf &amp;
"    golddimstate[stateCode]," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    FILTER ( ALL ( golddimpolicy[clientCode] ),           NOT ISBLANK ( golddimpolicy[clientCode] ) &amp;&amp; ( ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany ) )," &amp; vbCrLf &amp;
"    FILTER ( ALL ( golddimstate[stateCode] ),            NOT ISBLANK ( golddimstate[stateCode] )   &amp;&amp; ( ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState ) )," &amp; vbCrLf &amp;
"    FILTER ( ALL ( golddimpolicy[lobDesc] ),             NOT ISBLANK ( golddimpolicy[lobDesc] )    &amp;&amp; ( ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB ) )," &amp; vbCrLf &amp;
"    FILTER ( ALL ( golddimunderwriter[underwriterName] ), NOT ISBLANK ( golddimunderwriter[underwriterName] ) &amp;&amp; ( ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter ) )," &amp; vbCrLf &amp;
"    FILTER ( ALL ( golddimcarrier[carrierCode] ),        NOT ISBLANK ( golddimcarrier[carrierCode] )   &amp;&amp; ( ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier ) )," &amp; vbCrLf &amp;
"    FILTER ( ALL ( golddimagency[agencyName] ),                                                          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )," &amp; vbCrLf &amp;
"    FILTER ( 'DEP factpolicytransaction', 'DEP factpolicytransaction'[recordSource] = ""versions"" &amp;&amp; 'DEP factpolicytransaction'[transactionStatus] = ""Committed"" &amp;&amp; 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate &amp;&amp; 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""NewBusinessCount""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( DISTINCTCOUNT ( 'DEP factpolicytransaction'[policyNumber] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionNumber] = 0, 'DEP factpolicytransaction'[transactionType] = ""New Business"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""RenewalCount""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( DISTINCTCOUNT ( 'DEP factpolicytransaction'[policyNumber] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionType] = ""Renewal"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""CancelledCount""," &amp; vbCrLf &amp;
"        VAR PoliciesInCurrentContext = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( COUNTROWS ( FILTER ( PoliciesInCurrentContext, VAR CurrentPolicy = 'DEP factpolicytransaction'[policyNumber] VAR GlobalMaxTxnNumber = CALCULATE ( MAX ( 'DEP factpolicytransaction'[transactionNumber] ), ALL ( 'DEP factpolicytransaction' ), 'DEP factpolicytransaction'[policyNumber] = CurrentPolicy, 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ) VAR IsCancelled = CALCULATE ( COUNTROWS ( 'DEP factpolicytransaction' ), ALL ( 'DEP factpolicytransaction' ), 'DEP factpolicytransaction'[policyNumber] = CurrentPolicy, 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionNumber] = GlobalMaxTxnNumber, 'DEP factpolicytransaction'[policyStatus] = ""Policy Cancelled"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"" ) RETURN NOT ISBLANK ( IsCancelled ) &amp;&amp; IsCancelled &gt; 0 ) ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""GrossPremiumWritten""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( SUM ( 'DEP factpolicytransaction'[writtenPremium] ), FILTER ( 'DEP factpolicytransaction', 'DEP factpolicytransaction'[recordSource] = ""versions"" &amp;&amp; ( ISBLANK ( 'DEP factpolicytransaction'[transactionType] ) || ( 'DEP factpolicytransaction'[transactionType] &lt;&gt; ""Cancellation"" &amp;&amp; 'DEP factpolicytransaction'[transactionType] &lt;&gt; ""Cancellation - ProRate"" ) ) ), 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""PremiumsCancelled""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( SUM ( 'DEP factpolicytransaction'[writtenPremium] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionType] IN { ""Cancellation"", ""Cancellation - ProRate"" }, 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""NetPremiumWritten""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( SUM ( 'DEP factpolicytransaction'[writtenPremium] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""TermPremium""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( SUM ( 'DEP factpolicytransaction'[termPremium] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[policyStatus] = ""Policy In Force"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""TotalInforcePolicies""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( DISTINCTCOUNT ( 'DEP factpolicytransaction'[policyNumber] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[policyStatus] = ""Policy In Force"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""AvgTermMonths""," &amp; vbCrLf &amp;
"        COALESCE ( CALCULATE ( AVERAGEX ( 'DEP factpolicytransaction', DATEDIFF ( 'DEP factpolicytransaction'[policyEffectiveDate], 'DEP factpolicytransaction'[policyExpiryDate], MONTH ) ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""AvgInforcePremium""," &amp; vbCrLf &amp;
"        VAR InforcePrem = CALCULATE ( SUM ( 'DEP factpolicytransaction'[termPremium] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[policyStatus] = ""Policy In Force"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate )" &amp; vbCrLf &amp;
"        VAR InforcePolicies = CALCULATE ( DISTINCTCOUNT ( 'DEP factpolicytransaction'[policyNumber] ), 'DEP factpolicytransaction'[recordSource] = ""versions"", 'DEP factpolicytransaction'[policyStatus] = ""Policy In Force"", 'DEP factpolicytransaction'[transactionStatus] = ""Committed"", 'DEP factpolicytransaction'[transactionDate] &gt;= StartDate, 'DEP factpolicytransaction'[transactionDate] &lt;= EndDate )" &amp; vbCrLf &amp;
"        RETURN DIVIDE ( InforcePrem, InforcePolicies, 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""EarnedPremiums""," &amp; vbCrLf &amp;
"        VAR GrainPolicies = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionStatus] = ""Committed""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &gt;= StartDate," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &lt;= EndDate," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[clientCode] ),           ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimstate[stateCode] ),            ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[lobDesc] ),             ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimcarrier[carrierCode] ),        ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimagency[agencyName] ),          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( CALCULATE ( SUMX ( FILTER ( 'DEP factcoveragepremium', 'DEP factcoveragepremium'[recordSource] = ""versions"" &amp;&amp; NOT ISBLANK ( 'DEP factcoveragepremium'[transactionEffectiveDate] ) &amp;&amp; 'DEP factcoveragepremium'[transactionEffectiveDate] &lt;= EndDate ), VAR CurrentPolicy = 'DEP factcoveragepremium'[policyNumber] VAR CurrentCov = 'DEP factcoveragepremium'[coverageName] VAR TxnEff = 'DEP factcoveragepremium'[transactionEffectiveDate] VAR TxnNum = 'DEP factcoveragepremium'[transactionNumber] VAR TxnDate = 'DEP factcoveragepremium'[transactionDate] VAR TxnType = 'DEP factcoveragepremium'[transactionType] VAR PolStatus = 'DEP factcoveragepremium'[policyStatus] VAR ThisPPD = IF ( ISBLANK ( 'DEP factcoveragepremium'[premiumPerDay] ), 0, 'DEP factcoveragepremium'[premiumPerDay] ) VAR PolExp = 'DEP factcoveragepremium'[policyExpiryDate] VAR NextTxnEff = CALCULATE ( MIN ( 'DEP factcoveragepremium'[transactionEffectiveDate] ), FILTER ( ALL ( 'DEP factcoveragepremium' ), 'DEP factcoveragepremium'[recordSource] = ""versions"" &amp;&amp; 'DEP factcoveragepremium'[policyNumber] = CurrentPolicy &amp;&amp; 'DEP factcoveragepremium'[coverageName] = CurrentCov &amp;&amp; ( 'DEP factcoveragepremium'[transactionEffectiveDate] &gt; TxnEff || ( 'DEP factcoveragepremium'[transactionEffectiveDate] = TxnEff &amp;&amp; 'DEP factcoveragepremium'[transactionNumber] &gt; TxnNum ) ) ) ) VAR TxnEnd = IF ( ISBLANK ( NextTxnEff ), PolExp, NextTxnEff ) VAR EffectiveDays = SWITCH ( TRUE (), TxnType = ""Cancellation"", 0, TxnEff &lt; TxnDate &amp;&amp; TxnEnd &lt;= TxnDate &amp;&amp; TxnDate &gt;= StartDate &amp;&amp; TxnDate &lt;= EndDate, DATEDIFF ( TxnEff, TxnEnd, DAY ), TxnEff &lt; TxnDate &amp;&amp; TxnEnd &gt; TxnDate &amp;&amp; TxnDate &gt;= StartDate &amp;&amp; TxnDate &lt;= EndDate, DATEDIFF ( TxnEff, EndDate, DAY ), TxnEff &gt;= TxnDate &amp;&amp; TxnEnd &gt;= EndDate &amp;&amp; TxnEff &lt;= StartDate, DATEDIFF ( StartDate, EndDate, DAY ), TxnEff &gt;= TxnDate &amp;&amp; TxnEnd &lt; EndDate &amp;&amp; TxnEff &lt;= StartDate, DATEDIFF ( StartDate, TxnEnd, DAY ), TxnEff &gt;= TxnDate &amp;&amp; TxnEnd &gt;= EndDate &amp;&amp; TxnEff &gt; StartDate, DATEDIFF ( TxnEff, EndDate, DAY ), TxnEff &gt;= TxnDate &amp;&amp; TxnEnd &lt; EndDate &amp;&amp; TxnEff &gt; StartDate, DATEDIFF ( TxnEff, TxnEnd, DAY ), 0 ) RETURN IF ( PolStatus = ""Policy Cancelled"" || EffectiveDays &lt; 0, 0, EffectiveDays * ThisPPD ) ), TREATAS ( GrainPolicies, 'DEP factcoveragepremium'[policyNumber] ) ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""UnearnedPremiums""," &amp; vbCrLf &amp;
"        VAR GrainPolicies2 = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionStatus] = ""Committed""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &gt;= StartDate," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &lt;= EndDate," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[clientCode] ),           ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimstate[stateCode] ),            ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[lobDesc] ),             ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimcarrier[carrierCode] ),        ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimagency[agencyName] ),          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( CALCULATE ( SUMX ( FILTER ( 'DEP factcoveragepremium', 'DEP factcoveragepremium'[recordSource] = ""versions"" &amp;&amp; NOT ISBLANK ( 'DEP factcoveragepremium'[transactionEffectiveDate] ) &amp;&amp; 'DEP factcoveragepremium'[transactionEffectiveDate] &lt;= EndDate ), VAR CurrentPolicy2 = 'DEP factcoveragepremium'[policyNumber] VAR CurrentCov2 = 'DEP factcoveragepremium'[coverageName] VAR TxnEff2 = 'DEP factcoveragepremium'[transactionEffectiveDate] VAR TxnNum2 = 'DEP factcoveragepremium'[transactionNumber] VAR PolStatus2 = 'DEP factcoveragepremium'[policyStatus] VAR ThisPPD2 = IF ( ISBLANK ( 'DEP factcoveragepremium'[premiumPerDay] ), 0, 'DEP factcoveragepremium'[premiumPerDay] ) VAR PolExp2 = 'DEP factcoveragepremium'[policyExpiryDate] VAR MaxRank = CALCULATE ( MAXX ( FILTER ( ALL ( 'DEP factcoveragepremium' ), 'DEP factcoveragepremium'[recordSource] = ""versions"" &amp;&amp; 'DEP factcoveragepremium'[policyNumber] = CurrentPolicy2 &amp;&amp; 'DEP factcoveragepremium'[coverageName] = CurrentCov2 &amp;&amp; 'DEP factcoveragepremium'[transactionEffectiveDate] &lt;= EndDate ), 'DEP factcoveragepremium'[transactionNumber] * 1000000 + DATEDIFF ( DATE ( 2000, 1, 1 ), 'DEP factcoveragepremium'[transactionEffectiveDate], DAY ) ) ) VAR ThisRank = TxnNum2 * 1000000 + DATEDIFF ( DATE ( 2000, 1, 1 ), TxnEff2, DAY ) VAR UnearnedDays = DATEDIFF ( EndDate, PolExp2, DAY ) RETURN IF ( ThisRank &lt;&gt; MaxRank || PolStatus2 = ""Policy Cancelled"" || UnearnedDays &lt; 0, 0, UnearnedDays * ThisPPD2 ) ), TREATAS ( GrainPolicies2, 'DEP factcoveragepremium'[policyNumber] ) ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""FeesAndMisc""," &amp; vbCrLf &amp;
"        VAR GrainPolicies3 = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionStatus] = ""Committed""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &gt;= StartDate," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &lt;= EndDate," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[clientCode] ),           ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimstate[stateCode] ),            ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[lobDesc] ),             ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimcarrier[carrierCode] ),        ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimagency[agencyName] ),          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( CALCULATE ( SUM ( 'DEP factpolicycharges'[amount] ), TREATAS ( GrainPolicies3, 'DEP factpolicycharges'[policyNumber] ) ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""LossesIncurred""," &amp; vbCrLf &amp;
"        VAR GrainPolicies4 = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionStatus] = ""Committed""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &gt;= StartDate," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &lt;= EndDate," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[clientCode] ),           ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimstate[stateCode] ),            ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[lobDesc] ),             ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimcarrier[carrierCode] ),        ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimagency[agencyName] ),          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( CALCULATE ( SUM ( 'DEC factclaimfinancial'[amount] ), 'DEC factclaimfinancial'[finCategory] IN { ""R"", ""C"", ""%"", ""V"" }, TREATAS ( GrainPolicies4, 'DEC factclaimfinancial'[policyNumber] ) ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""AvgCommissionPct""," &amp; vbCrLf &amp;
"        VAR GrainPolicies5 = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionStatus] = ""Committed""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &gt;= StartDate," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &lt;= EndDate," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[clientCode] ),           ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimstate[stateCode] ),            ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[lobDesc] ),             ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimcarrier[carrierCode] ),        ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimagency[agencyName] ),          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( CALCULATE ( AVERAGE ( 'DDM factcommissionactivity'[commissionNbPercent] ), REMOVEFILTERS ( 'DDM factcommissionactivity' ), TREATAS ( GrainPolicies5, 'DDM factcommissionactivity'[policyNumber] ) ), 0 )," &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    ""SubAgentCommission""," &amp; vbCrLf &amp;
"        VAR GrainPolicies6 = CALCULATETABLE ( VALUES ( 'DEP factpolicytransaction'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionStatus] = ""Committed""," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &gt;= StartDate," &amp; vbCrLf &amp;
"                'DEP factpolicytransaction'[transactionDate] &lt;= EndDate," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[clientCode] ),           ParamCompany     = ""All"" || ParamCompany     = """" || golddimpolicy[clientCode]           = ParamCompany )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimstate[stateCode] ),            ParamState       = ""All"" || ParamState       = """" || golddimstate[stateCode]            = ParamState )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimpolicy[lobDesc] ),             ParamLOB         = ""All"" || ParamLOB         = """" || golddimpolicy[lobDesc]             = ParamLOB )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || ParamUnderwriter = """" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimcarrier[carrierCode] ),        ParamCarrier     = ""All"" || ParamCarrier     = """" || golddimcarrier[carrierCode]        = ParamCarrier )," &amp; vbCrLf &amp;
"                FILTER ( ALL ( golddimagency[agencyName] ),          ParamAgency      = ""All"" || ParamAgency      = """" || golddimagency[agencyName]          = ParamAgency )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"        RETURN COALESCE ( CALCULATE ( SUM ( 'DDM factcommissionactivity'[amount] ), REMOVEFILTERS ( 'DDM factcommissionactivity' ), TREATAS ( GrainPolicies6, 'DDM factcommissionactivity'[policyNumber] ) ), 0 )" &amp; vbCrLf &amp;
")" &amp; vbCrLf &amp;
"ORDER BY golddimpolicy[clientCode] ASC, golddimstate[stateCode] ASC"</CommandText>
      </Query>
      <Fields>
        <Field Name="clientCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>golddimpolicy[clientCode]</DataField>
        </Field>
        <Field Name="stateCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>golddimstate[stateCode]</DataField>
        </Field>
        <Field Name="NewBusinessCount">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[NewBusinessCount]</DataField>
        </Field>
        <Field Name="RenewalCount">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[RenewalCount]</DataField>
        </Field>
        <Field Name="CancelledCount">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[CancelledCount]</DataField>
        </Field>
        <Field Name="GrossPremiumWritten">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[GrossPremiumWritten]</DataField>
        </Field>
        <Field Name="PremiumsCancelled">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[PremiumsCancelled]</DataField>
        </Field>
        <Field Name="FeesAndMisc">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[FeesAndMisc]</DataField>
        </Field>
        <Field Name="NetPremiumWritten">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[NetPremiumWritten]</DataField>
        </Field>
        <Field Name="EarnedPremiums">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[EarnedPremiums]</DataField>
        </Field>
        <Field Name="UnearnedPremiums">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[UnearnedPremiums]</DataField>
        </Field>
        <Field Name="LossesIncurred">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[LossesIncurred]</DataField>
        </Field>
        <Field Name="AvgCommissionPct">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[AvgCommissionPct]</DataField>
        </Field>
        <Field Name="SubAgentCommission">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[SubAgentCommission]</DataField>
        </Field>
        <Field Name="InforcePremium">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[termPremium]</DataField>
        </Field>
        <Field Name="TotalInforcePolicies">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[TotalInforcePolicies]</DataField>
        </Field>
        <Field Name="AvgTermMonths">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[AvgTermMonths]</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!clientCode.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>=IIF(Parameters!Company.Value="All",Fields!clientCode.Value,Parameters!Company.Value)</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!stateCode.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>=IIF(Parameters!State.Value="All",Fields!stateCode.Value,Parameters!State.Value)</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="DSCompany">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE UNION(ROW("clientCode","All"),CALCULATETABLE(SUMMARIZECOLUMNS(golddimpolicy[clientCode]),NOT ISBLANK(golddimpolicy[clientCode]))) ORDER BY [clientCode] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="clientCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[clientCode]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSLOB">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE UNION(ROW("lobDesc","All"),CALCULATETABLE(SUMMARIZECOLUMNS(golddimpolicy[lobDesc]),NOT ISBLANK(golddimpolicy[lobDesc]))) ORDER BY [lobDesc] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="lobDesc">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[lobDesc]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSState">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE UNION(ROW("stateCode","All"),CALCULATETABLE(SUMMARIZECOLUMNS(golddimstate[stateCode]),NOT ISBLANK(golddimstate[stateCode]))) ORDER BY [stateCode] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="stateCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[stateCode]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSUnderwriter">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE
UNION (
    ROW ( "underwriterName", "All" ),
    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimunderwriter[underwriterName] ),
        NOT ISBLANK ( golddimunderwriter[underwriterName] )
    )
)
ORDER BY [underwriterName] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="underwriterName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[underwriterName]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSCarrier">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE
UNION (
    ROW ( "carrierCode", "All" ),
    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimcarrier[carrierCode] ),
        NOT ISBLANK ( golddimcarrier[carrierCode] )
    )
)
ORDER BY [carrierCode] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="carrierCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[carrierCode]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSAgency">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE
UNION (
    ROW ( "agencyName", "All" ),
    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimagency[agencyName] ),
        NOT ISBLANK ( golddimagency[agencyName] )
    )
)
ORDER BY [agencyName] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="agencyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[agencyName]</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
