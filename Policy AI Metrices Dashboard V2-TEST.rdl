  <Code>Public Function ConvertLocalToEastern(inputTime As DateTime) As String
    Try
        Dim localTime As DateTime = DateTime.SpecifyKind(inputTime, DateTimeKind.Local)
        Dim easternZone As TimeZoneInfo = TimeZoneInfo.FindSystemTimeZoneById("Eastern Standard Time")
        Dim easternTime As DateTime = TimeZoneInfo.ConvertTime(localTime, easternZone)
        Return easternTime.ToString("MM/dd/yyyy HH:mm:ss")
    Catch ex As Exception
        Return "Error: " &amp; ex.Message
    End Try
End Function
</Code>
