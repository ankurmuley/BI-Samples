            <Query>
              <Statement>EVALUATE SUMMARIZECOLUMNS('SR23217A_1'[coverage (groups)], 'SR23217A_1'[coverage], 'SR23217A_1'[coverage_desc], 'SR23217A_1'[netwritten], 'Dates_SR23217A_1'[MonthYear], 'SR23217A_1'[inforce_policies], 'Dates_SR23217A_1'[MonthStart], RSCustomDaxFilter(@DatesSR23217A1MonthYear,EqualToCondition,[Dates_SR23217A_1].[MonthYear],String), FILTER(VALUES('SR23217A_1'[date_range]), ('SR23217A_1'[date_range] = "1")), "LastMonthYear", [LastMonthYear])</Statement>
              <ParameterDefinitions>
                <ParameterDefinition>
                  <Name>DatesSR23217A1MonthYear</Name>
                  <DefaultValues>
                    <DefaultValue />
                  </DefaultValues>
                  <Caption>MonthYear</Caption>
                  <HierarchyUniqueName>[Dates_SR23217A_1].[MonthYear]</HierarchyUniqueName>
                  <ParameterValuesQuery>
                    <Statement>EVALUATE SELECTCOLUMNS (ADDCOLUMNS (SUMMARIZECOLUMNS (ROLLUPADDISSUBTOTAL ('Dates_SR23217A_1'[MonthYear], "h0")), "ParameterLevel", if ([h0], 0, 1)), "ParameterCaption", SWITCH([ParameterLevel], 1, 'Dates_SR23217A_1'[MonthYear], "Blank()"), "ParameterValue", 'Dates_SR23217A_1'[MonthYear], "ParameterLevel", [ParameterLevel], "'Dates_SR23217A_1'[MonthYear]", 'Dates_SR23217A_1'[MonthYear]) order by 'Dates_SR23217A_1'[MonthYear], [ParameterLevel]</Statement>
                    <ParameterizedStatement>
                      <ReferencedParameters />
                    </ParameterizedStatement>
                  </ParameterValuesQuery>
                  <MultipleValues>true</MultipleValues>
                  <AllowBlank>true</AllowBlank>
                </ParameterDefinition>
              </ParameterDefinitions>
            </Query>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>EVALUATE 
SUMMARIZECOLUMNS(
    'SR23217A_1'[coverage (groups)], 
    'SR23217A_1'[coverage], 
    'SR23217A_1'[coverage_desc], 
    'SR23217A_1'[UnearnedPrem],
     'SR23217A_1'[fees],  
    'Dates_SR23217A_1'[MonthYear], 
    'SR23217A_1'[inforce_policies], 
    'Dates_SR23217A_1'[MonthStart], 
    -- Filter 1: Multi-value MonthYear
    FILTER(
        VALUES('Dates_SR23217A_1'[MonthYear]),
        PATHCONTAINS(@DatesSR23217A1MonthYear, 'Dates_SR23217A_1'[MonthYear])
    ), 
    -- Filter 2: Date Range
    FILTER(
        VALUES('SR23217A_1'[date_range]), 
        'SR23217A_1'[date_range] = "1"
    ), 
 -- Filter 3: nan filter out
 FILTER(
VALUES(
'SR23217A_1'[coverage]
),
 ('SR23217A_1'[coverage] &lt;&gt; "nan")
),
    -- Extension: Measure
    "LastMonthYear", [LastMonthYear]
)</CommandText>
      </Query>
