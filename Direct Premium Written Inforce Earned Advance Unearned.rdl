"                    &amp;&amp; 'DEP factpolicytransaction'[policyExpiryDate] &gt; EndDt" &amp; vbCrLf &amp;
"                    &amp;&amp; DATEDIFF ( 'DEP factpolicytransaction'[policyEffectiveDate], 'DEP factpolicytransaction'[policyExpiryDate], DAY ) &gt; 0" &amp; vbCrLf &amp;
