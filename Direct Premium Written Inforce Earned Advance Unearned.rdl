"" &amp; vbCrLf &amp;
"    VAR Unearned_CY =" &amp; vbCrLf &amp;
"        CALCULATE (" &amp; vbCrLf &amp;
"            SUMX (" &amp; vbCrLf &amp;
"                FILTER (" &amp; vbCrLf &amp;
"                    'DEP factpolicytransaction'," &amp; vbCrLf &amp;
"                    'DEP factpolicytransaction'[accountingDate] &gt;= StartDt" &amp; vbCrLf &amp;
"                    &amp;&amp; 'DEP factpolicytransaction'[accountingDate] &lt;= EndDt" &amp; vbCrLf &amp;
