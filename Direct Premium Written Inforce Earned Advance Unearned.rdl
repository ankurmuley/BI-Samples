"    VAR ParamCarrier = """ &amp; Parameters!Carrier.Value &amp; """" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    VAR PremWrit_CY =" &amp; vbCrLf &amp;
"        CALCULATE (" &amp; vbCrLf &amp;
"            SUM ( 'DEP factpolicytransaction'[writtenPremium] )," &amp; vbCrLf &amp;
