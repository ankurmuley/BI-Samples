"            NOT ISBLANK ( golddimpolicy[lobDesc] )," &amp; vbCrLf &amp;
"            'DEP factpolicytransaction'[recordSource] = ""versions""," &amp; vbCrLf &amp;
"            FILTER ( ALL ( golddimpolicy[lobDesc] ), ParamLOB = ""All"" || golddimpolicy[lobDesc] = ParamLOB )," &amp; vbCrLf &amp;
"            FILTER ( ALL ( golddimstate[stateCode] ), ParamState = ""All"" || golddimstate[stateCode] = ParamState )," &amp; vbCrLf &amp;
"            FILTER ( ALL ( golddimagency[agencyName] ), ParamAgency = ""All"" || golddimagency[agencyName] = ParamAgency )," &amp; vbCrLf &amp;
