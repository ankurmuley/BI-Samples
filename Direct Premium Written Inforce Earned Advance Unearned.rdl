"            FILTER ( ALL ( golddimunderwriter[underwriterName] ), ParamUnderwriter = ""All"" || golddimunderwriter[underwriterName] = ParamUnderwriter )," &amp; vbCrLf &amp;
"            FILTER ( ALL ( golddimcarrier[carrierCode] ), ParamCarrier = ""All"" || golddimcarrier[carrierCode] = ParamCarrier )" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"EVALUATE" &amp; vbCrLf &amp;
"UNION (" &amp; vbCrLf &amp;
"    ROW (" &amp; vbCrLf &amp;
"        ""PolicyTypeDescription"", """"," &amp; vbCrLf &amp;
"        ""YearType"", ""CURRENT PERIOD""," &amp; vbCrLf &amp;
"        ""Sort"", 1," &amp; vbCrLf &amp;
"        ""PremWritten_CurrentMonth"", PremWrit_CM_CY," &amp; vbCrLf &amp;
"        ""PremWritten_YTD"", PremWrit_CY," &amp; vbCrLf &amp;
"        ""TotalInForce"", InForce_CY," &amp; vbCrLf &amp;
"        ""TotalUnearned"", Unearned_CY," &amp; vbCrLf &amp;
"        ""AdvanceWritten_CurrentMonth"", AdvanceWrit_CY," &amp; vbCrLf &amp;
"        ""AdvanceInForce"", AdvanceInForce_CY" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    ROW (" &amp; vbCrLf &amp;
"        ""PolicyTypeDescription"", ""PA Personal Auto""," &amp; vbCrLf &amp;
"        ""YearType"", ""PREVIOUS PERIOD""," &amp; vbCrLf &amp;
"        ""Sort"", 2," &amp; vbCrLf &amp;
"        ""PremWritten_CurrentMonth"", PremWrit_CM_PY," &amp; vbCrLf &amp;
"        ""PremWritten_YTD"", PremWrit_PY," &amp; vbCrLf &amp;
"        ""TotalInForce"", InForce_PY," &amp; vbCrLf &amp;
"        ""TotalUnearned"", Unearned_PY," &amp; vbCrLf &amp;
"        ""AdvanceWritten_CurrentMonth"", AdvanceWrit_PY," &amp; vbCrLf &amp;
"        ""AdvanceInForce"", AdvanceInForce_PY" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    ROW (" &amp; vbCrLf &amp;
"        ""PolicyTypeDescription"", """"," &amp; vbCrLf &amp;
"        ""YearType"", ""DIFFERENCE""," &amp; vbCrLf &amp;
"        ""Sort"", 3," &amp; vbCrLf &amp;
"        ""PremWritten_CurrentMonth"", COALESCE(PremWrit_CM_CY,0) - COALESCE(PremWrit_CM_PY,0)," &amp; vbCrLf &amp;
"        ""PremWritten_YTD"", COALESCE(PremWrit_CY,0) - COALESCE(PremWrit_PY,0)," &amp; vbCrLf &amp;
"        ""TotalInForce"", COALESCE(InForce_CY,0) - COALESCE(InForce_PY,0)," &amp; vbCrLf &amp;
"        ""TotalUnearned"", COALESCE(Unearned_CY,0) - COALESCE(Unearned_PY,0)," &amp; vbCrLf &amp;
"        ""AdvanceWritten_CurrentMonth"", COALESCE(AdvanceWrit_CY,0) - COALESCE(AdvanceWrit_PY,0)," &amp; vbCrLf &amp;
"        ""AdvanceInForce"", COALESCE(AdvanceInForce_CY,0) - COALESCE(AdvanceInForce_PY,0)" &amp; vbCrLf &amp;
"    )" &amp; vbCrLf &amp;
")" &amp; vbCrLf &amp;
"ORDER BY [Sort] ASC"</CommandText>
      </Query>
      <Fields>
        <Field Name="PolicyTypeDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[PolicyTypeDescription]</DataField>
        </Field>
        <Field Name="YearType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[YearType]</DataField>
        </Field>
        <Field Name="Sort">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[Sort]</DataField>
        </Field>
        <Field Name="PremWritten_CurrentMonth">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[PremWritten_CurrentMonth]</DataField>
        </Field>
        <Field Name="PremWritten_YTD">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[PremWritten_YTD]</DataField>
        </Field>
        <Field Name="TotalInForce">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[TotalInForce]</DataField>
        </Field>
        <Field Name="TotalUnearned">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[TotalUnearned]</DataField>
        </Field>
        <Field Name="AdvanceWritten_CurrentMonth">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[AdvanceWritten_CurrentMonth]</DataField>
        </Field>
        <Field Name="AdvanceInForce">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[AdvanceInForce]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSCompany">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE
UNION (
    ROW ( "clientCode", "All" ),
    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimpolicy[clientCode] ),
        NOT ISBLANK ( golddimpolicy[clientCode] )
    )
)
ORDER BY [clientCode] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="clientCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[clientCode]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSLOB">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
