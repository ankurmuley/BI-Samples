    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimpolicy[lobDesc] ),
        NOT ISBLANK ( golddimpolicy[lobDesc] )
    )
)
ORDER BY [lobDesc] ASC</CommandText>
