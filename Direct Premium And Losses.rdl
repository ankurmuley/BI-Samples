  <DataSets>
    <DataSet Name="DSDPLDetail">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>="DEFINE" &amp; vbCrLf &amp;
"    VAR StartDt = DATE(" &amp; Year(Parameters!StartDate.Value) &amp; "," &amp; Month(Parameters!StartDate.Value) &amp; "," &amp; Day(Parameters!StartDate.Value) &amp; ")" &amp; vbCrLf &amp;
"    VAR EndDt = DATE(" &amp; Year(Parameters!EndDate.Value) &amp; "," &amp; Month(Parameters!EndDate.Value) &amp; "," &amp; Day(Parameters!EndDate.Value) &amp; ")" &amp; vbCrLf &amp;
"    VAR ParamCarrier = """ &amp; Parameters!Carrier.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamLOB = """ &amp; Parameters!LOB.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamState = """ &amp; Parameters!State.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamAgency = """ &amp; Parameters!Agency.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamUnderwriter = """ &amp; Parameters!Underwriter.Value &amp; """" &amp; vbCrLf &amp;
"    VAR ParamAgencyLocation = """ &amp; Parameters!AgencyLocation.Value &amp; """" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    MEASURE 'DEP factcoveragepremium'[_GrossPW] =" &amp; vbCrLf &amp;
"        CALCULATE (" &amp; vbCrLf &amp;
"            SUM ( 'DEP factcoveragepremium'[effectivePremium] )," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[recordSource]    = ""versions""," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[transactionDate] &gt;= StartDt," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[transactionDate] &lt;= EndDt," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[transactionType] &lt;&gt; ""Cancellation""" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    MEASURE 'DEP factcoveragepremium'[_NetPW] =" &amp; vbCrLf &amp;
"        CALCULATE (" &amp; vbCrLf &amp;
"            SUM ( 'DEP factcoveragepremium'[effectivePremium] )," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[recordSource]    = ""versions""," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[transactionDate] &gt;= StartDt," &amp; vbCrLf &amp;
"            'DEP factcoveragepremium'[transactionDate] &lt;= EndDt" &amp; vbCrLf &amp;
"        )" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    MEASURE 'DDM factcommissionactivity'[_NetComm] =" &amp; vbCrLf &amp;
"        VAR _GrainPolicies =" &amp; vbCrLf &amp;
"            CALCULATETABLE (" &amp; vbCrLf &amp;
"                VALUES ( 'DEP factcoveragepremium'[policyNumber] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[coverageName] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[coverageDescription] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[mappedCoverageCode] )," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[recordSource]    = ""versions""," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[transactionDate] &gt;= StartDt," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[transactionDate] &lt;= EndDt" &amp; vbCrLf &amp;
"            )" &amp; vbCrLf &amp;
"        RETURN" &amp; vbCrLf &amp;
"            CALCULATE (" &amp; vbCrLf &amp;
"                SUM ( 'DDM factcommissionactivity'[amount] )," &amp; vbCrLf &amp;
"                TREATAS ( VALUES ( 'DEP factcoveragepremium'[coverageName] ), 'DDM factcommissionactivity'[coverageName] )," &amp; vbCrLf &amp;
"                TREATAS ( _GrainPolicies, 'DDM factcommissionactivity'[policyNumber] )," &amp; vbCrLf &amp;
"                'DDM factcommissionactivity'[transactionDate] &gt;= StartDt," &amp; vbCrLf &amp;
"                'DDM factcommissionactivity'[transactionDate] &lt;= EndDt" &amp; vbCrLf &amp;
"            )" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    MEASURE 'DEC factclaimfinancial'[_LossInc] =" &amp; vbCrLf &amp;
"        VAR _GrainPolicies =" &amp; vbCrLf &amp;
"            CALCULATETABLE (" &amp; vbCrLf &amp;
"                VALUES ( 'DEP factcoveragepremium'[policyNumber] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[coverageName] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[coverageDescription] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[mappedCoverageCode] )," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[recordSource]    = ""versions""," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[transactionDate] &gt;= StartDt," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[transactionDate] &lt;= EndDt" &amp; vbCrLf &amp;
"            )" &amp; vbCrLf &amp;
"        RETURN" &amp; vbCrLf &amp;
"            CALCULATE (" &amp; vbCrLf &amp;
"                SUM ( 'DEC factclaimfinancial'[amount] )," &amp; vbCrLf &amp;
"                TREATAS ( VALUES ( 'DEP factcoveragepremium'[mappedCoverageCode] ), 'DEC factclaimfinancial'[coverageCode] )," &amp; vbCrLf &amp;
"                TREATAS ( _GrainPolicies, 'DEC factclaimfinancial'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEC factclaimfinancial'[accountingDate] &gt;= StartDt," &amp; vbCrLf &amp;
"                'DEC factclaimfinancial'[accountingDate] &lt;= EndDt," &amp; vbCrLf &amp;
"                'DEC factclaimfinancial'[finCategory] = ""R""" &amp; vbCrLf &amp;
"                    || 'DEC factclaimfinancial'[finCategory] = ""C""" &amp; vbCrLf &amp;
"                    || 'DEC factclaimfinancial'[finCategory] = ""%""" &amp; vbCrLf &amp;
"            )" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"    MEASURE 'DEC factclaimfinancial'[_LossExp] =" &amp; vbCrLf &amp;
"        VAR _GrainPolicies =" &amp; vbCrLf &amp;
"            CALCULATETABLE (" &amp; vbCrLf &amp;
"                VALUES ( 'DEP factcoveragepremium'[policyNumber] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[coverageName] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[coverageDescription] )," &amp; vbCrLf &amp;
"                REMOVEFILTERS ( 'DEP factcoveragepremium'[mappedCoverageCode] )," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[recordSource]    = ""versions""," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[transactionDate] &gt;= StartDt," &amp; vbCrLf &amp;
"                'DEP factcoveragepremium'[transactionDate] &lt;= EndDt" &amp; vbCrLf &amp;
"            )" &amp; vbCrLf &amp;
"        RETURN" &amp; vbCrLf &amp;
"            CALCULATE (" &amp; vbCrLf &amp;
"                SUM ( 'DEC factclaimfinancial'[amount] )," &amp; vbCrLf &amp;
"                TREATAS ( VALUES ( 'DEP factcoveragepremium'[mappedCoverageCode] ), 'DEC factclaimfinancial'[coverageCode] )," &amp; vbCrLf &amp;
"                TREATAS ( _GrainPolicies, 'DEC factclaimfinancial'[policyNumber] )," &amp; vbCrLf &amp;
"                'DEC factclaimfinancial'[accountingDate] &gt;= StartDt," &amp; vbCrLf &amp;
"                'DEC factclaimfinancial'[accountingDate] &lt;= EndDt," &amp; vbCrLf &amp;
"                'DEC factclaimfinancial'[finCategory] = ""E""" &amp; vbCrLf &amp;
"            )" &amp; vbCrLf &amp;
"" &amp; vbCrLf &amp;
"EVALUATE" &amp; vbCrLf &amp;
"SUMMARIZECOLUMNS (" &amp; vbCrLf &amp;
"    'DEP factcoveragepremium'[coverageName]," &amp; vbCrLf &amp;
"    'DEP factcoveragepremium'[coverageDescription]," &amp; vbCrLf &amp;
"    'DEP factcoveragepremium'[mappedCoverageCode]," &amp; vbCrLf &amp;
"    'DEP factcoveragepremium'[lob]," &amp; vbCrLf &amp;
"    'DEP factcoveragepremium'[stateCode]," &amp; vbCrLf &amp;
"    'DEP factcoveragepremium'[companyCode]," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( 'DEP factcoveragepremium'[recordSource] )," &amp; vbCrLf &amp;
"        'DEP factcoveragepremium'[recordSource] = ""versions""" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( 'DEP factcoveragepremium'[transactionDate] )," &amp; vbCrLf &amp;
"        'DEP factcoveragepremium'[transactionDate] &gt;= StartDt" &amp; vbCrLf &amp;
"        &amp;&amp; 'DEP factcoveragepremium'[transactionDate] &lt;= EndDt" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( 'DEP factcoveragepremium'[coverageName]," &amp; vbCrLf &amp;
"              'DEP factcoveragepremium'[lob]," &amp; vbCrLf &amp;
"              'DEP factcoveragepremium'[companyCode] )," &amp; vbCrLf &amp;
"        NOT ISBLANK ( 'DEP factcoveragepremium'[coverageName] )" &amp; vbCrLf &amp;
"        &amp;&amp; NOT ISBLANK ( 'DEP factcoveragepremium'[lob] )" &amp; vbCrLf &amp;
"        &amp;&amp; NOT ISBLANK ( 'DEP factcoveragepremium'[companyCode] )" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( golddimcarrier[carrierCode] )," &amp; vbCrLf &amp;
"        ParamCarrier = ""All"" || golddimcarrier[carrierCode] = ParamCarrier" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( golddimlob[lobCode] )," &amp; vbCrLf &amp;
"        ParamLOB = ""All"" || golddimlob[lobCode] = ParamLOB" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( golddimstate[stateCode] )," &amp; vbCrLf &amp;
"        ParamState = ""All"" || golddimstate[stateCode] = ParamState" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( golddimagency[agencyName] )," &amp; vbCrLf &amp;
"        ParamAgency = ""All"" || golddimagency[agencyName] = ParamAgency" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( golddimunderwriter[underwriterName] )," &amp; vbCrLf &amp;
"        ParamUnderwriter = ""All"" || golddimunderwriter[underwriterName] = ParamUnderwriter" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    FILTER (" &amp; vbCrLf &amp;
"        ALL ( golddimagency[locationName] )," &amp; vbCrLf &amp;
"        ParamAgencyLocation = ""All"" || golddimagency[locationName] = ParamAgencyLocation" &amp; vbCrLf &amp;
"    )," &amp; vbCrLf &amp;
"    ""GrossPremiumWritten"", [_GrossPW]," &amp; vbCrLf &amp;
"    ""NetPremiumWritten"",   [_NetPW]," &amp; vbCrLf &amp;
"    ""NetCommission"",       [_NetComm]," &amp; vbCrLf &amp;
"    ""LossesIncurred"",      [_LossInc]," &amp; vbCrLf &amp;
"    ""LossExpense"",         [_LossExp]" &amp; vbCrLf &amp;
")" &amp; vbCrLf &amp;
"ORDER BY 'DEP factcoveragepremium'[lob] ASC, 'DEP factcoveragepremium'[coverageName] ASC"</CommandText>
      </Query>
      <Fields>
        <Field Name="coverageName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DEP factcoveragepremium[coverageName]</DataField>
        </Field>
        <Field Name="coverageDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DEP factcoveragepremium[coverageDescription]</DataField>
        </Field>
        <Field Name="mappedCoverageCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DEP factcoveragepremium[mappedCoverageCode]</DataField>
        </Field>
        <Field Name="lob">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DEP factcoveragepremium[lob]</DataField>
        </Field>
        <Field Name="stateCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DEP factcoveragepremium[stateCode]</DataField>
        </Field>
        <Field Name="companyCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DEP factcoveragepremium[companyCode]</DataField>
        </Field>
        <Field Name="GrossPremiumWritten">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[GrossPremiumWritten]</DataField>
        </Field>
        <Field Name="NetPremiumWritten">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[NetPremiumWritten]</DataField>
        </Field>
        <Field Name="NetCommission">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[NetCommission]</DataField>
        </Field>
        <Field Name="LossesIncurred">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[LossesIncurred]</DataField>
        </Field>
        <Field Name="LossExpense">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[LossExpense]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSCarriers">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE
UNION (
    ROW ( "carrierCode", "All" ),
    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimcarrier[carrierCode] ),
        NOT ISBLANK ( golddimcarrier[carrierCode] )
    )
)
ORDER BY [carrierCode] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="carrierCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[carrierCode]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSLOB">
      <Query>
        <DataSourceName>PROD_CFP_Workspace_Cogitate_Dashboard</DataSourceName>
        <CommandText>EVALUATE
UNION (
    ROW ( "lobCode", "All" ),
    CALCULATETABLE (
        SUMMARIZECOLUMNS ( golddimlob[lobCode] ),
        NOT ISBLANK ( golddimlob[lobCode] )
    )
)
ORDER BY [lobCode] ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="lobCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>[lobCode]</DataField>
        </Field>
      </Fields>
    </DataSet>
