        <ConnectString>Data Source=pbiazure://api.powerbi.com/;Identity Provider="https://login.microsoftonline.com/organizations, https://analysis.windows.net/powerbi/api, f0b72488-7082-488a-a7e8-eada97bd842d";Initial Catalog=sobe_wowvirtualserver-a3132530-218c-4c7b-a6ac-f43fa85d3490;Integrated Security=ClaimsToken</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>06e68c5a-0bd8-485c-8c0e-3afecc4d9226</rd:DataSourceID>
      <rd:PowerBIWorkspaceName>PROD_CFP_Workspace</rd:PowerBIWorkspaceName>
